<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width" /><title>Admin</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /></head><body><nav class="navbar navbar-expand navbar-dark bg-dark"><div class="container"><a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">Admin</a><div class="navbar-nav"><a class="nav-link" asp-controller="User" asp-action="Index">Users</a><a class="nav-link" asp-controller="Role" asp-action="Index">Roles</a></div><div class="ms-auto">@if(User.Identity?.IsAuthenticated==true){<form asp-controller="Account" asp-action="Logout" method="post"><button class="btn btn-sm btn-light">Logout</button></form>}else{<a class="btn btn-sm btn-light" asp-controller="Account" asp-action="Login">Login</a>}</div></div></nav><main class="container py-4">@RenderBody()</main><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>@await RenderSectionAsync("Scripts", false)</body></html>