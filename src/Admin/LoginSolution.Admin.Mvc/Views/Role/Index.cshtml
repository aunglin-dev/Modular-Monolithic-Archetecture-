@model IReadOnlyList<RoleResponseModel>
<h1 class="h4">Roles</h1><a class="btn btn-primary mb-3" asp-action="Create">Create role</a><table class="table table-sm"><thead><tr><th>ID</th><th>Name</th><th>Description</th><th></th></tr></thead><tbody>@foreach(var r in Model ?? Array.Empty<RoleResponseModel>()){<tr><td>@r.Id</td><td>@r.Name</td><td>@r.Description</td><td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.Id">Edit</a></td></tr>}</tbody></table>