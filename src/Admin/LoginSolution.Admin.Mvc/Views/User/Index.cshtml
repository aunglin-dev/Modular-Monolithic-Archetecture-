@model UserListModel
<h1 class="h4">Users</h1><a class="btn btn-primary mb-3" asp-action="Create">Create user</a>@if(Model is null){<div class="alert alert-warning">Users unavailable.</div>}else{<table class="table table-sm"><thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var u in Model.Users){<tr><td>@u.Id</td><td>@u.FirstName @u.LastName</td><td>@u.Email</td><td>@string.Join(", ", u.Roles)</td><td>@(u.IsActive ? "Active" : "Inactive")</td><td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Edit</a><form asp-action="Status" method="post" class="d-inline"><input type="hidden" name="id" value="@u.Id" /><input type="hidden" name="isActive" value="@(!u.IsActive)" /><button class="btn btn-sm btn-outline-secondary">@(u.IsActive ? "Deactivate" : "Activate")</button></form></td></tr>}</tbody></table>}