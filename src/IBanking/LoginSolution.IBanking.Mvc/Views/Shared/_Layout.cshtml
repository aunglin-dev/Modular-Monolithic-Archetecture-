<!DOCTYPE html>
<html><head><meta name="viewport" content="width=device-width" /><title>IBanking</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /></head><body><nav class="navbar navbar-expand navbar-dark bg-primary"><div class="container"><a class="navbar-brand" asp-controller="Home" asp-action="Index">IBanking</a><div class="navbar-nav"><a class="nav-link" asp-controller="Profile" asp-action="Index">Profile</a><a class="nav-link" asp-controller="Profile" asp-action="Account">Account</a><a class="nav-link" asp-controller="Profile" asp-action="Balance">Balance</a></div><div class="ms-auto">@if (User.Identity?.IsAuthenticated == true) { <form asp-controller="Account" asp-action="Logout" method="post"><button class="btn btn-sm btn-light">Logout</button></form> } else { <a class="btn btn-sm btn-light" asp-controller="Account" asp-action="Login">Login</a> }</div></div></nav><main class="container py-4">@RenderBody()</main><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>@await RenderSectionAsync("Scripts", false)</body></html>