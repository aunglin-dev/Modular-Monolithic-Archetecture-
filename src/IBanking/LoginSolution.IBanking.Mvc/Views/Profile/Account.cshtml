@model AccountResponseModel
<h1 class="h4">Account details</h1>@if(Model is null){<div class="alert alert-warning">Account unavailable.</div>}else{<table class="table"><tr><th>Number</th><td>@Model.AccountNumber</td></tr><tr><th>Name</th><td>@Model.AccountName</td></tr><tr><th>Status</th><td>@Model.Status</td></tr><tr><th>Balance</th><td>@Model.Balance.ToString("C")</td></tr></table>}